      -- Rev
      WHEN BR_HIT_DES = 'NOHIT' AND SegmentoScore = 18 AND SCORE_TD BETWEEN 0   AND 213  THEN 5         
      WHEN BR_HIT_DES = 'NOHIT' AND SegmentoScore = 18 AND SCORE_TD BETWEEN 214 AND 253  THEN 4             
