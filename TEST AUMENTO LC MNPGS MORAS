    *,

CASE 
    WHEN BR_HIT_DES IN ('THIN FILE','NOHIT')
         AND RiskLevelMinipagos IN (1,2,3)
         AND BR_IMP_LIM_CRED_APROB = 1200
    THEN 2000

    ELSE LEAST(
            GREATEST(
                ROUND((BR_ING_TOT * GREATEST(PTIMaxMinipagos - PTI,0) * 12)/500)*500,
                LCMinMinipagos
            ),
            LCMaxMinipagos
         )
